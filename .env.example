# ─── Core ────────────────────────────────────────────────────
PORT=5591
LAZY_TOOL_SERVICE_API_KEY=<YOUR_API_KEY>
NODE_ENV=production

# ─── CORS (optional — comma-separated additional origins) ───
# CORS_ORIGINS=http://192.168.1.100:3000,http://custom-domain:8888

# ─── Python Execution ──────────────────────────────────────
# PYTHON_INTERPRETER=/opt/venv/bin/python
# PYTHON_EXEC_SCRIPT=/app/python/scripts/execute_tool.py
# PYTHON_CWD=/app/python
# PYTHONPATH=/app/python
# EXECUTION_TIMEOUT_MS=30000

# ─── Trading Service ──────────────────────────────────────
TRADING_SERVICE_URL=http://<YOUR_NAS_IP>:3031
TRADING_SERVICE_API_KEY=<YOUR_TRADING_SERVICE_API_KEY>

# ─── MongoDB (optional) ──────────────────────────────────
# MONGO_URI=mongodb://<MONGO_USER>:<MONGO_PASS>@<YOUR_NAS_IP>:27017/?directConnection=true&authSource=admin

# ─── Cache ───────────────────────────────────────────────
# CACHE_TTL_MS=60000

# ─── HTML Notes ──────────────────────────────────────────────
HTML_NOTES_URL=http://10.0.0.16:8035
